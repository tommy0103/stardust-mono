---
import type { ReadingItem } from '../../../data/readings';

interface Props {
  readings: ReadingItem[];
}

const { readings } = Astro.props;
const displayReadings = readings.slice(0, 3);

const statusIcons: Record<ReadingItem['status'], string> = {
  reading: '📖',
  pending: '📌',
  finished: '✅',
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    month: 'short',
    day: 'numeric',
  });
}
---

<article class="bento-card">
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-serif text-lg font-semibold text-[var(--apoc-ink)]">最新阅读</h2>
    <a href="/readings" class="text-xs text-[var(--apoc-accent)] hover:underline">
      查看全部 →
    </a>
  </div>
  
  <div class="flex flex-col gap-2.5">
    {displayReadings.map((item) => (
      <a 
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-3 rounded-lg border border-[var(--glass-border-soft)] bg-white/40 p-3 transition-all hover:bg-white/60"
      >
        <span class="shrink-0 text-base">{statusIcons[item.status]}</span>
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-medium text-[var(--apoc-ink)] group-hover:text-[var(--apoc-accent)] transition-colors line-clamp-1">
            {item.title}
            <span class="ml-1 text-[var(--apoc-faint)] opacity-0 group-hover:opacity-100 transition-opacity">↗</span>
          </h3>
          <div class="mt-1 flex items-center gap-2 text-xs text-[var(--apoc-muted)]">
            <span>{item.source}</span>
            <span>·</span>
            <time>{formatDate(item.addedAt)}</time>
          </div>
        </div>
      </a>
    ))}
  </div>
</article>
