---
import Layout from '../core/layouts/Layout.astro';
import LatestPostsCard from '../core/components/bento/LatestPostsCard.astro';
import LatestReadingsCard from '../core/components/bento/LatestReadingsCard.astro';
import ActivityStreamCard from '../core/components/bento/ActivityStreamCard.astro';
import CommitGraphCard from '../core/components/bento/CommitGraphCard.astro';
import { getCollection } from 'astro:content';
import { mockReadings } from '../data/readings';
import { fetchGitHubContributions } from '../data/github';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const sortedReadings = [...mockReadings].sort(
  (a, b) => b.addedAt.getTime() - a.addedAt.getTime()
);

const githubData = await fetchGitHubContributions();
---

<Layout
  title="Mio's Notes — 数字花园"
  description="亮色液态玻璃风格的笔记归档：Markdown 与 LaTeX 可读排版。"
>
  <main id="main" class="relative">
    <!-- Hero Section -->
    <section data-cascade="0" class="mx-auto max-w-6xl px-5 pb-6 pt-12 md:px-6 md:pb-10 md:pt-16">
      <div class="glass-panel-strong px-6 py-10 md:px-10 md:py-14">
        <p
          class="mb-3 font-mono text-xs uppercase tracking-[0.22em] text-[var(--apoc-faint)]"
        >
          Digital garden
        </p>
        <h1
          class="font-serif text-3xl font-bold leading-[1.12] tracking-tight text-[var(--apoc-ink)] md:text-4xl"
        >
          Eureka & Entropy-
        </h1>
        <p
          class="mt-4 max-w-2xl text-base leading-relaxed text-[var(--apoc-muted)] md:text-lg"
        >
          Life is too short to be ordinary——<span class="italic">"Wir müssen wissen. Wir werden wissen."</span>
        </p>
      </div>
    </section>

    <!-- Bento Grid -->
    <section data-cascade="1" class="mx-auto max-w-6xl px-5 pb-16 md:px-6">
      <div class="bento-grid">
        <!-- Row 1: Latest Posts (large) + Activity Stream (tall, spans 2 rows) -->
        <div class="bento-area-posts">
          <LatestPostsCard posts={sortedPosts} />
        </div>
        
        <div class="bento-area-activity">
          <ActivityStreamCard />
        </div>
        
        <!-- Row 2: Readings + Commit Graph -->
        <div class="bento-area-readings">
          <LatestReadingsCard readings={sortedReadings} />
        </div>
        
        <div class="bento-area-commits">
          <CommitGraphCard data={githubData} />
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  
  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: 1.2fr 0.8fr;
      grid-template-rows: auto auto;
      gap: 1.25rem;
    }
    
    .bento-area-posts {
      grid-column: 1;
      grid-row: 1;
    }
    
    .bento-area-activity {
      grid-column: 2;
      grid-row: 1 / 3;
    }
    
    .bento-area-readings {
      grid-column: 1;
      grid-row: 2;
    }
    
    .bento-area-commits {
      display: none;
    }
  }
  
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr 0.8fr;
      grid-template-rows: auto auto;
    }
    
    .bento-area-posts {
      grid-column: 1 / 3;
      grid-row: 1;
    }
    
    .bento-area-activity {
      grid-column: 3;
      grid-row: 1 / 3;
    }
    
    .bento-area-readings {
      grid-column: 1;
      grid-row: 2;
    }
    
    .bento-area-commits {
      display: block;
      grid-column: 2;
      grid-row: 2;
    }
  }
</style>

<style is:global>
  .bento-card {
    background: var(--glass-fill);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border: 1px solid var(--glass-border-soft);
    border-radius: 1.25rem;
    padding: 1.25rem;
    box-shadow: 0 4px 16px rgba(72, 95, 150, 0.06);
    height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .bento-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(72, 95, 150, 0.1);
  }
  
  .bento-card-large {
    min-height: 280px;
  }
  
  .bento-card-tall {
    min-height: 100%;
  }
</style>
