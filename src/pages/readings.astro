---
import Layout from '../core/layouts/Layout.astro';
import ReadingCard from '../core/components/ReadingCard.astro';
import { mockReadings, type ReadingItem } from '../data/readings';

const statusLabels: Record<ReadingItem['status'], string> = {
  reading: '正在阅读',
  pending: '待读',
  finished: '已读完',
};

const statusColors: Record<ReadingItem['status'], string> = {
  reading: 'bg-amber-100 text-amber-700 border-amber-200',
  pending: 'bg-slate-100 text-slate-600 border-slate-200',
  finished: 'bg-emerald-100 text-emerald-700 border-emerald-200',
};

const sortedReadings = [...mockReadings].sort(
  (a, b) => b.addedAt.getTime() - a.addedAt.getTime()
);

const readingItems = sortedReadings.filter((r) => r.status === 'reading');
const pendingItems = sortedReadings.filter((r) => r.status === 'pending');
const finishedItems = sortedReadings.filter((r) => r.status === 'finished');
---

<Layout
  title="阅读记录 — Mio's Notes"
  description="正在阅读和想看的文章、资料归档。"
>
  <main id="main" class="relative">
    <section data-cascade="0" class="mx-auto max-w-6xl px-5 pb-6 pt-12 md:px-6 md:pb-10 md:pt-16">
      <div class="glass-panel-strong px-6 py-12 md:px-10 md:py-16">
        <p
          class="mb-4 font-mono text-xs uppercase tracking-[0.22em] text-[var(--apoc-faint)]"
        >
          Reading List
        </p>
        <h1
          class="font-serif text-4xl font-bold leading-[1.12] tracking-tight text-[var(--apoc-ink)] md:text-5xl"
        >
          阅读记录
        </h1>
        <p
          class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--apoc-muted)] md:text-xl"
        >
          收集值得一读的文章、博客、论文……<br />
          <span class="italic">"We are what we repeatedly read."</span>
        </p>
        <div class="mt-8 flex flex-wrap gap-3 text-sm">
          <span class="inline-flex items-center gap-1.5 rounded-full border bg-amber-50 border-amber-200 px-3 py-1 text-amber-700">
            <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
            正在阅读 {readingItems.length}
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border bg-slate-50 border-slate-200 px-3 py-1 text-slate-600">
            <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
            待读 {pendingItems.length}
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border bg-emerald-50 border-emerald-200 px-3 py-1 text-emerald-700">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            已读完 {finishedItems.length}
          </span>
        </div>
      </div>
    </section>

    {readingItems.length > 0 && (
      <section data-cascade="1" class="mx-auto max-w-6xl px-5 py-6 md:px-6">
        <div
          class="mb-6 flex items-center gap-3 rounded-xl border border-amber-200/60 bg-amber-50/50 px-4 py-3 backdrop-blur-sm"
        >
          <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse"></span>
          <h2 class="font-serif text-lg font-semibold text-[var(--apoc-ink)]">正在阅读</h2>
        </div>
        <div class="flex flex-col gap-4">
          {readingItems.map((item) => (
            <ReadingCard 
              item={item}
              statusLabel={statusLabels[item.status]}
              statusColor={statusColors[item.status]}
            />
          ))}
        </div>
      </section>
    )}

    {finishedItems.length > 0 && (
      <section data-cascade="2" class="mx-auto max-w-6xl px-5 py-6 md:px-6">
        <div
          class="mb-6 flex items-center gap-3 rounded-xl border border-emerald-200/60 bg-emerald-50/50 px-4 py-3 backdrop-blur-sm"
        >
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <h2 class="font-serif text-lg font-semibold text-[var(--apoc-ink)]">已读完</h2>
        </div>
        <div class="flex flex-col gap-4">
          {finishedItems.map((item) => (
            <ReadingCard 
              item={item}
              statusLabel={statusLabels[item.status]}
              statusColor={statusColors[item.status]}
            />
          ))}
        </div>
      </section>
    )}

    {pendingItems.length > 0 && (
      <section data-cascade="3" class="mx-auto max-w-6xl px-5 py-6 md:px-6">
        <div
          class="mb-6 flex items-center gap-3 rounded-xl border border-slate-200/60 bg-slate-50/50 px-4 py-3 backdrop-blur-sm"
        >
          <span class="h-2 w-2 rounded-full bg-slate-400"></span>
          <h2 class="font-serif text-lg font-semibold text-[var(--apoc-ink)]">待读</h2>
        </div>
        <div class="flex flex-col gap-4">
          {pendingItems.map((item) => (
            <ReadingCard 
              item={item}
              statusLabel={statusLabels[item.status]}
              statusColor={statusColors[item.status]}
            />
          ))}
        </div>
      </section>
    )}

    <footer
      data-cascade="4"
      class="mx-auto mt-10 mb-16 max-w-6xl px-5 md:px-6"
    >
      <div class="rounded-2xl border border-[var(--glass-border-soft)] bg-[var(--glass-fill)] px-4 py-8 text-center text-sm text-[var(--apoc-muted)] backdrop-blur-md">
        <p>共 {sortedReadings.length} 篇阅读记录</p>
      </div>
    </footer>
  </main>
</Layout>
